---
import {
  IoAdd,
  IoPieChart,
  IoRadioButtonOn,
  IoPhonePortrait,
  IoArrowForward,
} from "react-icons/io5";

type FeatureItem = {
  title: string;
  description: string;
  href: string;
  icon: any;
};

const features: FeatureItem[] = [
  {
    title: "Pencatatan Cepat",
    description:
      "Pantau transaksi lebih rapi dengan kategori otomatis dan saldo yang selalu terbarui.",
    href: "#tracking",
    icon: IoAdd,
  },
  {
    title: "Analitik Visual",
    description:
      "Pahami pola keuangan melalui grafik ringkas untuk keputusan finansial yang lebih cerdas.",
    href: "#analytics",
    icon: IoPieChart,
  },
  {
    title: "Target Anggaran",
    description:
      "Tetapkan batas pengeluaran harian dan pantau progresnya agar tetap disiplin menabung.",
    href: "#budget-goals",
    icon: IoRadioButtonOn,
  },
  {
    title: "Akses Fleksibel",
    description:
      "Kelola keuangan di mana saja via mobile atau web dengan sinkronisasi data instan.",
    href: "#cross-platform",
    icon: IoPhonePortrait,
  },
];
---

<section
  id="features"
  class="bg-slate-50 px-6 py-20 md:px-12 md:py-28"
  aria-labelledby="features-title"
>
  <div class="mx-auto max-w-7xl">
    <header class="mx-auto max-w-3xl text-center">
      <h2
        id="features-title"
        class="text-balance text-3xl font-black tracking-tight text-slate-950 sm:text-4xl md:text-5xl"
      >
        Kelola Keuangan Jadi <span class="text-emerald-700">Lebih Simpel</span>
      </h2>
      <p
        class="mt-4 text-pretty text-base leading-relaxed text-slate-700 font-medium md:text-lg"
      >
        Alat cerdas yang dirancang untuk membantu Anda memahami arus kas tanpa
        ribet.
      </p>
    </header>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((feature) => {
          const Icon = feature.icon;
          return (
            <article class="group relative flex flex-col justify-between rounded-3xl border border-slate-200 bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:border-emerald-300 hover:shadow-xl hover:shadow-emerald-600/5">
              <div>
                <div
                  class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700 transition-colors group-hover:bg-emerald-600 group-hover:text-white"
                  aria-hidden="true"
                >
                  <Icon size={24} />
                </div>
                <h3 class="mt-6 text-xl font-bold text-slate-950 group-hover:text-emerald-800">
                  {feature.title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-700 font-medium">
                  {feature.description}
                </p>
              </div>
              <a
                href={feature.href}
                class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-emerald-700 transition-all hover:gap-3 outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 rounded-lg"
                aria-label={`Pelajari detail tentang ${feature.title}`}
              >
                Pelajari Detail
                <IoArrowForward aria-hidden="true" />
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style is:global>
  html {
    scroll-behavior: smooth !important;
  }
  #features,
  #testimonials,
  #pricing {
    scroll-margin-top: 6rem;
  }
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto !important;
    }
  }
</style>
