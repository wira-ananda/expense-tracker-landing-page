---
import {
  IoAdd,
  IoPieChart,
  IoRadioButtonOn,
  IoPhonePortrait,
} from "react-icons/io5";

type FeatureItem = {
  title: string;
  description: string;
  href: string;
  icon: typeof IoAdd;
  iconLabel: string;
};

const features: FeatureItem[] = [
  {
    title: "Catat Pemasukan & Pengeluaran",
    description:
      "Pantau setiap transaksi dengan lebih rapi melalui pencatatan yang cepat, kategori yang terstruktur, dan saldo yang selalu terbarui.",
    href: "#tracking",
    icon: IoAdd,
    iconLabel: "Fitur pencatatan pemasukan dan pengeluaran",
  },
  {
    title: "Analitik yang Mudah Dipahami",
    description:
      "Lihat pola keuangan Anda melalui visual yang ringkas, informatif, dan membantu Anda mengambil keputusan dengan lebih percaya diri.",
    href: "#analytics",
    icon: IoPieChart,
    iconLabel: "Fitur analitik visual",
  },
  {
    title: "Target Anggaran yang Jelas",
    description:
      "Tetapkan batas pengeluaran untuk setiap kebutuhan dan pantau progresnya secara real-time agar keuangan tetap terkendali.",
    href: "#budget-goals",
    icon: IoRadioButtonOn,
    iconLabel: "Fitur target anggaran",
  },
  {
    title: "Akses di Mobile & Web",
    description:
      "Kelola keuangan kapan saja dan di mana saja melalui perangkat mobile maupun web dengan pengalaman yang tetap nyaman dan konsisten.",
    href: "#cross-platform",
    icon: IoPhonePortrait,
    iconLabel: "Fitur akses lintas platform",
  },
];
---

<section
  class="bg-[#f5f5f5] px-7 py-16 md:px-20 md:py-24"
  aria-labelledby="features-title"
>
  <div class="mx-auto w-full max-w-400">
    <header class="mx-auto max-w-5xl text-center">
      <h2
        id="features-title"
        class="text-2xl font-bold tracking-[-0.04em] text-slate-950 md:text-6xl"
      >
        Semua yang Anda Butuhkan untuk Mengelola Keuangan
      </h2>

      <p
        class="mx-auto mt-4 max-w-4xl text-sm font-medium leading-relaxed text-slate-600 md:text-2xl"
      >
        ExpenseTracker membantu Anda mencatat transaksi, mengatur anggaran, dan
        memahami kondisi keuangan dengan cara yang lebih sederhana dan efektif.
      </p>
    </header>

    <div
      class="mt-14 grid grid-cols-1 gap-6 md:mt-16 md:grid-cols-2 xl:grid-cols-4"
    >
      {
        features.map((feature) => {
          const Icon = feature.icon;

          return (
            <article class="group h-full">
              <a
                href={feature.href}
                aria-label={feature.title}
                class="block h-full rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-none transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_14px_32px_rgba(15,23,42,0.10)] focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2"
              >
                <div
                  class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-500 transition-transform duration-300 group-hover:scale-105"
                  aria-hidden="true"
                >
                  <Icon className="h-6 w-6" />
                </div>

                <h3 class="mt-8 text-2xl font-bold tracking-[-0.03em] text-slate-950">
                  {feature.title}
                </h3>

                <p class="mt-5 text-lg font-medium leading-relaxed text-slate-600">
                  {feature.description}
                </p>
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
