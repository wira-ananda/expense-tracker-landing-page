---
import { IoWallet } from "react-icons/io5";

type NavItem = {
  label: string;
  href: string;
};

const navItems: NavItem[] = [
  { label: "Fitur", href: "#features" },
  { label: "Harga", href: "#pricing" },
  { label: "Testimoni", href: "#testimonials" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-6 lg:px-12"
  >
    <a
      href="/"
      class="group inline-flex items-center gap-2.5 rounded-lg outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 focus-visible:ring-offset-2"
      aria-label="ExpenseTracker Home"
    >
      <div
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-600 text-white shadow-sm transition-transform duration-300 group-hover:rotate-12"
        aria-hidden="true"
      >
        <IoWallet size={20} />
      </div>
      <span class="text-lg font-black tracking-tight text-slate-950 md:text-xl">
        Expense<span class="text-emerald-700">Tracker</span>
      </span>
    </a>

    <nav aria-label="Main Navigation" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "px-4 py-2 text-sm font-semibold transition-all duration-200 rounded-full outline-none focus-visible:ring-2 focus-visible:ring-emerald-600",
                  currentPath === item.href
                    ? "text-emerald-800 bg-emerald-100"
                    : "text-slate-700 hover:text-emerald-700 hover:bg-slate-100",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/login"
        class="hidden sm:inline-flex px-4 py-2 text-sm font-bold text-slate-800 hover:text-emerald-700 transition-colors outline-none focus-visible:underline"
      >
        Masuk
      </a>
      <a
        href="/register"
        class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-bold text-white shadow-md transition-all hover:bg-emerald-700 active:scale-95 outline-none focus-visible:ring-2 focus-visible:ring-slate-950 focus-visible:ring-offset-2"
      >
        Mulai Gratis
      </a>
    </div>
  </div>
</header>
