---
import { IoWallet } from "react-icons/io5";

type NavItem = {
  label: string;
  href: string;
};

const navItems: NavItem[] = [{ label: "Login", href: "/login" }];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur supports-backdrop-filter:bg-white/80"
>
  <div
    class="mx-auto flex h-18 md:h-20 w-full items-center justify-between px-7 sm:px-20 lg:max-w-450"
  >
    <a
      href="/"
      class="inline-flex items-center gap-4 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2"
      aria-label="ExpenseTracker home"
    >
      <span
        class="inline-flex h-9 w-9 md:h-11 md:w-11 items-center justify-center rounded-lg bg-emerald-500 text-white"
        aria-hidden="true"
      >
        <IoWallet className="h-5 w-5 md:h-7 md:w-7" />
      </span>

      <span
        class="hidden md:flex md:text-3xl font-extrabold tracking-[-0.02em] text-slate-900"
      >
        ExpenseTracker
      </span>
    </a>

    <nav
      aria-label="Primary navigation"
      class="flex items-center gap-2 sm:gap-4"
    >
      <ul class="flex items-center gap-2 sm:gap-3">
        {
          navItems.map((item) => {
            const isActive = currentPath === item.href;
            return (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive ? "page" : undefined}
                  class:list={[
                    "rounded-lg px-2 md:px-3 py-2 text-sm font-medium text-slate-700 transition-colors duration-200 md:text-xl",
                    "hover:text-emerald-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2",
                    isActive && "text-slate-900",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <a
        href="/register"
        class="inline-flex items-center justify-center rounded-xl bg-emerald-500 px-4 md:px-5 py-2 md:py-3 text-sm md:text-xl font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-emerald-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2"
        aria-label="Register for ExpenseTracker"
      >
        Register
      </a>
    </nav>
  </div>
</header>
