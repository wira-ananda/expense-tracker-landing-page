---
import {
  IoWallet,
  IoLogoGithub,
  IoLogoTwitter,
  IoLogoLinkedin,
} from "react-icons/io5";

const footerSections = [
  {
    title: "Produk",
    links: [
      { label: "Fitur Utama", href: "#features" },
      { label: "Keamanan Data", href: "#security" },
      { label: "Aplikasi Mobile", href: "#mobile" },
    ],
  },
  {
    title: "Bantuan",
    links: [
      { label: "Pusat Bantuan", href: "#help" },
      { label: "FAQ", href: "#faq" },
      { label: "Kontak Kami", href: "#contact" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Privasi", href: "/privacy" },
      { label: "Ketentuan", href: "/terms" },
      { label: "Cookie", href: "/cookie" },
    ],
  },
];
const currentYear = new Date().getFullYear();
---

<footer
  class="bg-slate-950 border-t border-white/10 px-6 pt-16 pb-8 text-slate-300"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-5">
        <a
          href="/"
          class="flex items-center gap-2.5 text-white outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 rounded-lg w-fit"
          aria-label="ExpenseTracker Beranda"
        >
          <div
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-600 text-white shadow-sm"
            aria-hidden="true"
          >
            <IoWallet size={18} />
          </div>
          <span class="text-xl font-bold tracking-tight">ExpenseTracker</span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed font-medium">
          Solusi cerdas kelola keuangan pribadi. Catat pengeluaran, atur
          anggaran, dan capai kebebasan finansial lebih cepat.
        </p>
        <div class="mt-6 flex gap-4">
          {
            [
              { Icon: IoLogoGithub, label: "Github" },
              { Icon: IoLogoTwitter, label: "Twitter" },
              { Icon: IoLogoLinkedin, label: "Linkedin" },
            ].map((item) => (
              <a
                href="#"
                class="text-slate-400 hover:text-emerald-400 transition-colors outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 rounded-full p-1"
                aria-label={`Kunjungi ${item.label} kami`}
              >
                <item.Icon size={24} aria-hidden="true" />
              </a>
            ))
          }
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:col-span-7">
        {
          footerSections.map((section) => (
            <nav aria-label={`Navigasi ${section.title}`}>
              <h2 class="text-sm font-bold uppercase tracking-widest text-white">
                {section.title}
              </h2>
              <ul class="mt-4 space-y-3">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm font-semibold hover:text-emerald-400 transition-colors outline-none focus-visible:text-emerald-400"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ))
        }
      </div>
    </div>

    <div
      class="mt-16 border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-bold uppercase tracking-wider"
    >
      <p>&copy; {currentYear} ExpenseTracker. Made with ❤️ in Indonesia.</p>
      <p>
        Created by <a
          href="https://wiraananda.vercel.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white hover:text-emerald-400 transition-colors underline outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 rounded"
          >wiraa</a
        >
      </p>
    </div>
  </div>
</footer>
