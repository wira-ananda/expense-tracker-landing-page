---
import {
  IoCart,
  IoBriefcase,
  IoCheckmarkCircle,
  IoArrowForward,
} from "react-icons/io5";
---

<section
  class="relative overflow-hidden bg-slate-950 px-6 py-12 md:px-12 md:py-24 lg:px-20"
  aria-labelledby="hero-title"
>
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-gradient-to-b from-emerald-900/40 to-slate-950"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.15]"
      style="background-image: radial-gradient(#10b981 0.5px, transparent 0.5px); background-size: 24px 24px;"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-2 lg:gap-16"
  >
    <header
      class="flex flex-col items-center text-center lg:items-start lg:text-left"
    >
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 backdrop-blur-md"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"
          ></span>
        </span>
        <span
          class="text-[10px] font-bold uppercase tracking-widest text-emerald-300 md:text-xs"
          >Update v2.0 Kini Tersedia</span
        >
      </div>

      <h1
        id="hero-title"
        class="text-balance text-4xl font-black leading-[1.1] tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl"
      >
        Kelola Uang Lebih <span
          class="bg-gradient-to-r from-emerald-400 to-teal-300 bg-clip-text text-transparent"
          >Tenang.</span
        >
      </h1>

      <p
        class="mt-6 max-w-xl text-balance text-base leading-relaxed text-slate-200 md:text-xl font-medium"
      >
        Berhenti menebak ke mana uang Anda pergi. Atur budget otomatis dan catat
        pengeluaran hanya dalam hitungan detik dengan sistem yang simpel.
      </p>

      <div
        class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-3 lg:justify-start"
      >
        {
          ["Tanpa Kartu Kredit", "Setup 1 Menit"].map((text) => (
            <div class="flex items-center gap-2 text-sm font-bold text-emerald-400">
              <IoCheckmarkCircle
                className="h-5 w-5 shrink-0"
                aria-hidden="true"
              />
              <span>{text}</span>
            </div>
          ))
        }
      </div>

      <div
        class="mt-10 flex w-full flex-col gap-4 sm:flex-row sm:justify-center lg:justify-start"
      >
        <a
          href="/register"
          class="group inline-flex items-center justify-center gap-2 rounded-2xl bg-emerald-300 px-8 py-4 text-base font-bold text-black transition-all hover:bg-emerald-500 hover:shadow-xl hover:shadow-emerald-600/20 active:scale-95 outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
          Mulai Gratis
          <IoArrowForward
            className="transition-transform group-hover:translate-x-1"
            aria-hidden="true"
          />
        </a>
        <a
          href="#demo"
          class="inline-flex items-center justify-center rounded-2xl border-2 border-white/20 bg-white/5 px-8 py-4 text-base font-bold text-white backdrop-blur-sm transition-all hover:bg-white/10 hover:border-white/40 outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
          Lihat Demo
        </a>
      </div>
    </header>

    <div class="relative mx-auto w-full max-w-md lg:ml-auto lg:mr-0">
      <div
        class="absolute -inset-10 z-0 bg-emerald-500/20 blur-[100px] rounded-full"
        aria-hidden="true"
      >
      </div>

      <article
        class="relative z-10 w-full transform rounded-[2.5rem] bg-white p-4 shadow-2xl ring-1 ring-slate-200 transition-all duration-500 ease-out lg:rotate-3 lg:hover:rotate-0 lg:hover:scale-[1.02]"
      >
        <div class="rounded-4xl bg-slate-50 p-5 md:p-6 border border-slate-200">
          <div class="flex items-center justify-between mb-6">
            <div>
              <p
                class="text-[10px] font-bold uppercase tracking-widest text-slate-700"
              >
                Total Saldo
              </p>
              <p class="text-2xl font-black text-slate-900 md:text-3xl">
                Rp12.800.000
              </p>
            </div>
            <time
              datetime="2025-12"
              class="rounded-lg bg-emerald-900 px-3 py-1 text-[10px] font-bold text-white"
              >Des 2025</time
            >
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div
              class="rounded-2xl bg-white p-3 md:p-4 shadow-sm border border-emerald-100"
            >
              <span class="text-[9px] font-black uppercase text-emerald-900"
                >Masuk</span
              >
              <p class="text-base font-black text-emerald-900 md:text-lg">
                6.5jt
              </p>
            </div>
            <div
              class="rounded-2xl bg-white p-3 md:p-4 shadow-sm border border-rose-100"
            >
              <span class="text-[9px] font-black uppercase text-rose-900"
                >Keluar</span
              >
              <p class="text-base font-black text-rose-900 md:text-lg">4.2jt</p>
            </div>
          </div>
        </div>

        <div class="mt-6 px-2 pb-2">
          <div class="flex items-center justify-between mb-4">
            <h2
              class="text-xs font-black text-slate-900 uppercase tracking-wider"
            >
              Aktivitas Terbaru
            </h2>
            <button
              class="text-[10px] font-bold text-emerald-900 hover:text-emerald-700 hover:underline outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 rounded px-1"
              >Semua</button
            >
          </div>

          <div class="space-y-3">
            {
              [
                {
                  title: "Belanja Bulanan",
                  date: "Supermarket",
                  price: "-150rb",
                  type: "out",
                  icon: IoCart,
                },
                {
                  title: "Gaji Freelance",
                  date: "Transfer",
                  price: "+5.0jt",
                  type: "in",
                  icon: IoBriefcase,
                },
              ].map((item) => (
                <div class="flex items-center justify-between rounded-xl p-2 transition-colors hover:bg-slate-50">
                  <div class="flex items-center gap-3">
                    <div
                      class:list={[
                        "flex h-9 w-9 items-center justify-center rounded-lg",
                        item.type === "out"
                          ? "bg-rose-100 text-rose-900"
                          : "bg-emerald-100 text-emerald-900",
                      ]}
                      aria-hidden="true"
                    >
                      <item.icon size={18} />
                    </div>
                    <div>
                      <p class="text-sm font-bold text-slate-900">
                        {item.title}
                      </p>
                      <p class="text-[10px] text-slate-800 font-bold">
                        {item.date}
                      </p>
                    </div>
                  </div>
                  <span
                    class:list={[
                      "text-sm font-black",
                      item.type === "out"
                        ? "text-rose-900"
                        : "text-emerald-900",
                    ]}
                  >
                    {item.price}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
