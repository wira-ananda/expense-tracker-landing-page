---
import { IoCart, IoBriefcase } from "react-icons/io5";
---

<section
  class="bg-linear-to-b from-[#11a36f] to-slate-950 px-7 py-10 md:px-20 md:py-16"
  aria-labelledby="hero-title"
>
  <div
    class="mx-auto grid min-h-[calc(100vh-5rem)] xl:min-h-[calc(100vh-5rem)] 2xl:min-h-[calc(85vh-5rem)] w-full max-w-400 items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]"
  >
    <div id="highlight" class="max-w-3xl">
      <h1
        id="hero-title"
        class="max-w-[15ch] text-4xl font-bold leading-12 md:leading-20 tracking-[-0.04em] text-white md:text-7xl"
      >
        Kelola Uang Lebih Tenang, Wujudkan Impian
      </h1>

      <p
        class="mt-3 md:mt-7 max-w-2xl text-md font-medium leading-relaxed text-white/95 sm:text-2xl"
      >
        Berhenti menebak ke mana uang Anda pergi. Atur budget, catat pengeluaran
        harian, dan capai target finansial Anda dengan lebih simpel.
      </p>

      <div class="mt-7 flex flex-wrap items-center gap-4 sm:gap-5">
        <a
          href="/register"
          class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 md:px-7 md:py-4 text-md font-medium text-black transition-all duration-300 hover:-translate-y-1 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-white sm:text-2xl"
          aria-label="Daftar gratis ExpenseTracker"
        >
          Mulai Sekarang — Gratis
        </a>

        <a
          href="#demo"
          class="inline-flex items-center justify-center rounded-2xl border-2 border-white/30 bg-white/10 px-5 py-3 md:px-7 md:py-4 text-md font-medium text-white backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 focus:outline-none sm:text-2xl"
          aria-label="Lihat cara kerja aplikasi"
        >
          Lihat Demo
        </a>
      </div>
    </div>

    <div id="card" class="flex justify-center md:justify-end">
      <article
        aria-label="Tampilan dashboard keuangan"
        class="group w-full rounded-4xl bg-[#f8f9fa] md:p-5 shadow-[0_32px_64px_rgba(0,0,0,0.15)] transition-transform duration-500 ease-out lg:rotate-[1.5deg] lg:hover:rotate-0 pb-5"
      >
        <div class="rounded-3xl bg-white p-5 shadow-sm sm:p-6">
          <div class="flex items-start justify-between gap-4">
            <h2
              class="text-[1rem] font-extrabold tracking-tight text-slate-900 md:text-[1.5rem]"
            >
              Laporan Bulan Ini
            </h2>

            <p class="pt-1 text-xs font-semibold text-slate-400 md:text-lg">
              Desember 2024
            </p>
          </div>

          <div class="mt-6 grid gap-3 sm:gap-4 grid-cols-2">
            <section
              aria-labelledby="income-title"
              class="rounded-2xl bg-emerald-50 p-3 sm:p-5 border border-emerald-100"
            >
              <h3
                id="income-title"
                class="text-[10px] font-bold uppercase tracking-wider text-emerald-600 sm:text-sm"
              >
                Pemasukan
              </h3>
              <p
                class="mt-1 text-lg font-black tracking-tight text-emerald-700 md:text-[2rem]"
              >
                Rp6.5jt
              </p>
            </section>

            <section
              aria-labelledby="expense-title"
              class="rounded-2xl bg-rose-50 p-3 sm:p-5 border border-rose-100"
            >
              <h3
                id="expense-title"
                class="text-[10px] font-bold uppercase tracking-wider text-rose-600 sm:text-sm"
              >
                Pengeluaran
              </h3>
              <p
                class="mt-1 text-lg font-black tracking-tight text-rose-700 md:text-[2rem]"
              >
                Rp4.2jt
              </p>
            </section>
          </div>

          <section
            aria-labelledby="balance-title"
            class="mt-4 rounded-2xl bg-slate-900 p-4 md:p-5 text-white"
          >
            <h3
              id="balance-title"
              class="text-[10px] font-medium text-slate-400 sm:text-sm"
            >
              Uang Aman Kamu (Sisa Saldo)
            </h3>
            <p
              class="mt-1 text-xl font-black tracking-tight text-white md:text-[2.5rem]"
            >
              +Rp2.300.000
            </p>
          </section>
        </div>

        <div class="mt-6 md:px-2 px-5 md:space-y-3 space-y-2">
          <h4
            class="text-[10px] font-bold uppercase tracking-widest text-slate-400"
          >
            Transaksi Terakhir
          </h4>

          <div
            class="flex items-center justify-between gap-4 border-b border-slate-100 pb-3 md:pb-0"
          >
            <div class="flex min-w-0 items-center gap-3">
              <div
                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-rose-100 text-rose-600"
              >
                <IoCart className="h-4 w-4" />
              </div>
              <div class="min-w-0">
                <p
                  class="truncate text-xs font-bold text-slate-900 md:text-base"
                >
                  Belanja Mingguan
                </p>
                <p class="text-[10px] font-medium text-slate-400">Baru saja</p>
              </div>
            </div>
            <p class="shrink-0 text-xs font-black text-rose-600 md:text-base">
              -Rp150rb
            </p>
          </div>

          <div class="flex items-center justify-between gap-4">
            <div class="flex min-w-0 items-center gap-3">
              <div
                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600"
              >
                <IoBriefcase className="h-4 w-4" />
              </div>
              <div class="min-w-0">
                <p
                  class="truncate text-xs font-bold text-slate-900 md:text-base"
                >
                  Gaji Freelance
                </p>
                <p class="text-[10px] font-medium text-slate-400">Kemarin</p>
              </div>
            </div>
            <p
              class="shrink-0 text-xs font-black text-emerald-600 md:text-base"
            >
              +Rp5jt
            </p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
